    {"from_step": "approve", "to_step": "hr_confirm", "action_trigger": "Approve", "condition_type": "Always"},
    {"from_step": "approve", "to_step": "fill_form", "action_trigger": "Reject", "condition_type": "Always"},
    {"from_step": "hr_confirm", "to_step": "end", "action_trigger": "Send", "condition_type": "Always"}
  ]
